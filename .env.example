# Versión común de las imágenes construidas por Docker Compose.
APP_VERSION=1.0.0

# PostgreSQL
POSTGRES_USER=innovatech
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_HOST_PORT=15433

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN
KEYCLOAK_PUBLIC_URL=http://localhost:8085
KEYCLOAK_HOST_PORT=8085
KEYCLOAK_MANAGEMENT_HOST_PORT=19000
KEYCLOAK_REALM=innovatech
KEYCLOAK_CLIENT_ID=innovatech-frontend

# Usuarios de demostración; el script de aprovisionamiento consume estos valores.
DEMO_ADMIN_PASSWORD=CHANGE_ME_DEMO_ADMIN
DEMO_PO_PASSWORD=CHANGE_ME_DEMO_PO
DEMO_DEV_PASSWORD=CHANGE_ME_DEMO_DEV

# Aplicación y puertos públicos locales
FRONTEND_HOST_PORT=5173
BFF_HOST_PORT=8090
API_GATEWAY_HOST_PORT=8080
EUREKA_HOST_PORT=8761
MS_EQUIPOS_HOST_PORT=8081
MS_PROYECTOS_HOST_PORT=8082
MS_TAREAS_HOST_PORT=8083

FRONTEND_PUBLIC_URL=http://localhost:5173
BFF_PUBLIC_URL=http://localhost:8090
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Solo para integración local/contenedores. En producción se recomienda validate + migraciones.
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
